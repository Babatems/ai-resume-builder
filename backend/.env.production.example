# Production Environment Variables
# Copy this file to .env and fill in with production values

# Server Configuration
PORT=5000
NODE_ENV=production

# Database Configuration (Use MongoDB Atlas for production)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ai-resume-builder?retryWrites=true&w=majority

# JWT Configuration (Generate secure random string)
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_production_jwt_secret_key_here

# Hugging Face API Configuration
HUGGING_FACE_API_KEY=your_huggingface_api_key

# CORS Configuration (Add your frontend URL)
ALLOWED_ORIGINS=https://your-netlify-domain.netlify.app,https://yourdomain.com

# Rate Limiting
FREE_TIER_MONTHLY_LIMIT=5
PRO_TIER_MONTHLY_LIMIT=50

# File Upload
MAX_FILE_SIZE=10485760
